---
// Base layout — carries all SEO + GEO signals.
// GEO = Generative Engine Optimization: structured data + clear semantics
// so AI engines (ChatGPT, Gemini, Perplexity) can cite this page.
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';

const {
  title,
  description,
  jsonld,          // optional array/object of schema.org JSON-LD
  ogType = 'website',
  noindex = false, // true for /login, /admin — keep them out of the index
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const schemas = jsonld ? (Array.isArray(jsonld) ? jsonld : [jsonld]) : [];

// Pick the auto-generated branded OG image for this page (scripts/gen-og.mjs).
const seg = Astro.url.pathname.split('/').filter(Boolean);
let ogKey = 'default';
if (seg[0] === 'states' && seg[1]) ogKey = `state-${seg[1]}`;
else if (seg[0] === 'brands' && seg[1]) ogKey = `brand-${seg[1]}`;
else if (seg[0] === 'learn' && seg[1]) ogKey = `learn-${seg[1]}`;
const ogImage = new URL(`/og/${ogKey}.png`, Astro.site).href;
---
<!doctype html>
<html lang="en-IN">
  <head>
    <!-- Google Tag Manager -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XRXMVC2JLC"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XRXMVC2JLC');
    </script>
    <!-- End Google Tag Manager -->

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google-site-verification" content="90DcfDRqzUQgO_P_bMt_EgeUw0UPHGmuNshSxeZqAvg" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />

    <!-- Open Graph / social -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Mind the Pour" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts (free, Google Fonts). Loaded non-render-blocking: the browser
         fetches the stylesheet at high priority via `preload`, then swaps it
         to an active stylesheet on load instead of blocking first paint on
         it. `font-display: swap` (baked into the Google Fonts URL) then lets
         text render in a fallback font immediately, avoiding invisible text
         while the webfont downloads. <noscript> covers the no-JS case. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Lora:ital,wght@0,400..700;1,400..700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Lora:ital,wght@0,400..700;1,400..700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Lora:ital,wght@0,400..700;1,400..700&display=swap" />
    </noscript>

    <!-- schema.org structured data (the GEO signal) -->
    {schemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <header class="site">
      <a href="/" class="brand" style="display:flex; align-items:center; gap:0.6rem;">
        <Image
          src={logo}
          alt="Mind the Pour Logo"
          width={56}
          height={56}
          loading="eager"
          fetchpriority="high"
          style="height:28px; width:28px; border-radius:4px;"
        />
        MIND&nbsp;THE&nbsp;POUR
      </a>
      <nav>
        <a href="/states/">Prices by State</a>
        <a href="/prices/">Price Map</a>
        <a href="/brands/">Brands</a>
        <a href="/learn/">Learn</a>
        <a href="/glossary/">Glossary</a>
        <a href="https://instagram.com/mindthepour" class="btn btn--nav" rel="me">Follow @mindthepour →</a>
      </nav>
    </header>
    <main class="wrap">
      <slot />
    </main>
    <footer class="site">
      <p>Mind the Pour — the business, pricing &amp; culture behind every drink in India.</p>
      <p><a href="/about/">About</a> · <a href="/learn/">Learn</a> · <a href="/responsible-drinking/">Responsible Drinking</a> · <a href="https://instagram.com/mindthepour">Instagram</a></p>
      <p class="fine">Editorial &amp; educational content about the alcohol <em>industry</em>. Not a seller of alcohol. <strong>21+ only. Please drink responsibly.</strong></p>
    </footer>

    <style is:global>
      :root {
        --ink: #1c1a17; --surface: #F3EFE6; --amber: #E2A829;
        --green: #2C5545; --cream: #FAF7F2; --stone: #8E8A83; --red: #C33124;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0; background: var(--cream); color: var(--ink);
        font-family: 'Lora', Georgia, serif;
        font-size: 1.125rem; line-height: 1.7;
        -webkit-font-smoothing: antialiased;
      }
      h1, h2, h3, .brand { font-family: 'Playfair Display', serif; line-height: 1.15; }
      /* Even line lengths on headings; fewer orphans in prose. */
      h1, h2, h3 { text-wrap: balance; }
      p, li { text-wrap: pretty; }

      /* Vertical rhythm: sections need to breathe more than paragraphs do,
         otherwise long explainers read as one undifferentiated wall. */
      h1 { font-size: clamp(1.9rem, 5vw, 2.6rem); margin: 0 0 1rem; letter-spacing: -0.02em; }
      h2 { font-size: 1.5rem; margin: 2.75rem 0 .75rem; letter-spacing: -0.01em; }
      h3 { font-size: 1.15rem; margin: 1.75rem 0 .5rem; }
      p { margin: 0 0 1.15rem; }
      section { margin-bottom: .5rem; }

      .highlight-red { color: var(--red); font-style: italic; }
      .badge-urgent { display: inline-block; background: var(--red); color: var(--cream); font-size: 0.7rem; font-weight: 800; text-transform: uppercase; padding: 0.2rem 0.6rem; border-radius: 3px; letter-spacing: 0.05em; vertical-align: middle; margin-right: 0.5rem; }
      a { color: var(--green); text-decoration: none; }
      a:hover { text-decoration: underline; color: var(--ink); }
      /* Visible keyboard focus — the dark theme swallows the UA default. */
      :where(a, button, summary, input, select, textarea):focus-visible {
        outline: 2px solid var(--green); outline-offset: 2px; border-radius: 3px;
      }
      header.site, footer.site {
        display: flex; flex-wrap: wrap; gap: 1rem; justify-content: space-between;
        align-items: center; padding: 1rem 1.5rem; background: var(--surface);
      }
      header.site nav { display: flex; gap: 1.25rem; flex-wrap: wrap; }
      .brand { color: var(--ink); font-weight: 900; letter-spacing: .02em; font-family: 'Playfair Display', serif; }
      /* The container is sized for tables and cards; prose inside it is capped
         separately at a readable measure. Previously everything ran to ~90ch,
         which is well past the 65-75ch comfort range for long-form reading. */
      .wrap { max-width: 820px; margin: 0 auto; padding: 2.5rem 1.5rem; }
      /* 34em ≈ 70 rendered characters. NOT `ch` — that unit is the width of the
         "0" glyph, which Inter draws much wider than its average letter, so
         `68ch` actually renders ~88 characters. Measured, not assumed. */
      .wrap :is(p, ul, ol, blockquote) { max-width: 34em; }
      /* Cards and tables set their own width; don't cap prose inside them. */
      .wrap :is(.card, td, th) :is(p, ul, ol) { max-width: none; }
      footer.site { flex-direction: column; align-items: flex-start; color: var(--stone); font-size: .85rem; }
      .fine { font-size: .8rem; }
      .hero-num { font-family: 'Playfair Display', serif; font-weight: 900; font-size: clamp(3rem, 10vw, 6rem); color: var(--amber); }
      /* A stat-led CTA under the H1: converts hero curiosity into a click
         instead of leaving the reader to scroll and hope. */
      .btn {
        display: inline-block; margin: .25rem 0 0; padding: .75rem 1.4rem;
        background: var(--amber); color: var(--ink); border-radius: 8px;
        font-family: 'Space Grotesk', sans-serif; font-weight: 700;
        letter-spacing: -0.01em; transition: transform .15s ease, opacity .15s ease;
      }
      .btn:hover { text-decoration: none; opacity: .92; transform: translateY(-1px); }
      /* Compact nav variant of .btn: Instagram is the primary channel (the
         grading metric), so it gets a CTA pill instead of a plain text link
         buried in the nav list. */
      .btn--nav { padding: .4rem .9rem; font-size: .85rem; margin: 0; }
      /* Stat-led cards: the number leads (reusing .hero-num, scaled down),
         the label follows — flips card hierarchy from "here's a category"
         to "here's a fact", per the state/explainer card redesign. */
      .card--stat { display: flex; align-items: baseline; gap: .9rem; flex-wrap: wrap; }
      .card--stat .hero-num { font-size: clamp(1.5rem, 5vw, 2rem); line-height: 1; flex-shrink: 0; }
      .card--stat .card-copy { color: var(--ink); flex: 1 1 14rem; }
      /* Wide tables scroll inside their own box so the page body never scrolls
         sideways on a phone — all of our search clicks so far are mobile. */
      .table-scroll { overflow-x: auto; margin: 1.5rem 0; -webkit-overflow-scrolling: touch; }
      .table-scroll table { margin: 0; }
      table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: .95rem; }
      th, td { text-align: left; padding: .7rem .6rem; border-bottom: 1px solid #d4cfc5; }
      th { color: var(--ink); font-weight: 600; white-space: nowrap; }
      .card {
        display: block; background: var(--surface); border: 1px solid #d4cfc5;
        border-radius: 12px; padding: 1rem 1.2rem; margin: .6rem 0;
      }
      .card:hover { border-color: var(--green); text-decoration: none; }
      .tag { display: inline-block; font-size: .75rem; color: var(--cream); background: var(--green);
        padding: .1rem .5rem; border-radius: 999px; font-weight: 600; }
      details { background: var(--surface); border-radius: 10px; padding: .5rem 1rem; margin: .5rem 0; }
      summary { cursor: pointer; font-weight: 600; color: var(--ink); }
    </style>
    <script>
      import Lenis from 'lenis';
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis({
        autoRaf: true,
      });

      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });
      gsap.ticker.lagSmoothing(0);

      window.lenis = lenis;
      window.gsap = gsap;
      window.ScrollTrigger = ScrollTrigger;
    </script>
  </body>
</html>
