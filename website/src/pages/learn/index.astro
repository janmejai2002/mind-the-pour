---
import Base from '../../layouts/Base.astro';
import explainers from '../../data/explainers.json';
import { getPublishedPosts, toExplainer } from '../../lib/posts.js';

// Same merge as /learn/[slug] — otherwise team posts would build with no
// internal link pointing at them, which kills their crawlability.
const posts = await getPublishedPosts();
const taken = new Set(explainers.map((e) => e.slug));
const all = [...explainers, ...posts.filter((p) => !taken.has(p.slug)).map(toExplainer)];

const title = 'Learn: The Economics of Alcohol in India, Explained';
const description = 'Plain-English explainers on liquor taxes, GST, pour cost, standard drinks, surrogate advertising, premiumization and more — the economics of what India drinks.';

// Group by pillar so the index reads as a structured hub rather than a flat
// dump — better for users, and a clearer topical signal for crawlers.
const byPillar = new Map();
for (const e of all) {
  if (!byPillar.has(e.pillar)) byPillar.set(e.pillar, []);
  byPillar.get(e.pillar).push(e);
}

const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: all.map((e, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: new URL(`/learn/${e.slug}/`, Astro.site).href,
    name: e.seoTitle ?? e.title,
  })),
};
---
<Base title={title} description={description} jsonld={jsonld}>
  <h1>Learn the economics of what India drinks</h1>
  <p>Straight answers to the questions people actually ask about alcohol in India — pricing,
  taxes, bars, branding and drinking smart.</p>

  {[...byPillar.entries()].map(([pillar, items]) => (
    <section>
      <h2>{pillar}</h2>
      {items.map((e) => (
        <a class="card" href={`/learn/${e.slug}/`}>
          <strong>{e.title}</strong>
          <p style="margin:.35rem 0 0;font-size:.88rem;color:var(--stone)">{e.angle}</p>
        </a>
      ))}
    </section>
  ))}
</Base>
